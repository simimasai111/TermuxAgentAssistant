<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LLM 配置"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Provider"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinner_provider"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_input"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Base URL"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/edit_base_url"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="12dp"
            android:inputType="textUri" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="API Key"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/edit_api_key"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="sk-... / xai-... / AI..."
            android:background="@drawable/bg_input"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="12dp"
            android:inputType="textPassword" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Model ID"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/edit_model_id"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Max Tokens"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/edit_max_tokens"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="2048"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="12dp"
            android:inputType="number" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Temperature (0.0 - 2.0)"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/edit_temperature"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="0.1"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="24dp"
            android:inputType="numberDecimal" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginVertical="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Termux 环境"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bootstrap 下载镜像（\$arch 自动替换为 arm 架构）"
            android:textSize="12sp"
            android:textColor="#999999"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/edit_bootstrap_mirror"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="https://github.com/termux/termux-packages/releases/download/bootstrap-archives/bootstrap-\$arch.zip"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="24dp"
            android:inputType="textUri"
            android:textSize="11sp" />

        <Button
            android:id="@+id/btn_test"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="测试 LLM 连接"
            android:backgroundTint="#FF9800"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="保存配置"
            android:backgroundTint="#1B5E20" />

    </LinearLayout>

</ScrollView>
